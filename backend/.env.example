# freesslcert.net backend — environment variables
#
# For any VAR, you can instead set VAR_FILE to a file path containing the
# secret value; this is used in production via Docker secrets.

# Runtime
APP_ENV=development           # development | production
APP_PORT=8080

# Database (Turso / libSQL)
DATABASE_URL=libsql://your-db.turso.io?authToken=...

# ACME / Let's Encrypt
ACME_EMAIL=you@example.com
ACME_DIRECTORY_URL=https://acme-staging-v02.api.letsencrypt.org/directory

# Deployment region tag — written into domain_log.region for usage metrics.
# Recommended values: us-east, eu-west, sg, jp, uk, au-syd. Defaults to "unknown".
REGION=us-east

# Optional integrations
CLOUDFLARE_API_TOKEN=
RESEND_API_KEY=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://freesslcert.net

# Rate limiting
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
