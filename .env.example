# Application
APP_ENV=development
APP_PORT=8080

# Database
DB_PATH=./data/freesslcert.db

# ACME / Certificate Generation
ACME_DATA_DIR=./data/acme
ACME_EMAIL=admin@freesslcert.net
# Production: https://acme-v02.api.letsencrypt.org/directory
ACME_DIRECTORY_URL=https://acme-staging-v02.api.letsencrypt.org/directory

# Cloudflare (for DNS-01 challenge)
CLOUDFLARE_API_TOKEN=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Rate Limiting
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# Frontend (used during build)
# VITE_API_BASE_URL=https://api.freesslcert.net
